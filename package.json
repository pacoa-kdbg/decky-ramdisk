{
  "name": "decky-ramdisk",
  "version": "0.0.1",
  "description": "Decky Loader plugin for staging selected Steam games on a temporary RAM disk.",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TBD/decky-ramdisk.git"
  },
  "keywords": ["decky", "steam-deck", "ramdisk", "steam-library"],
  "author": "TBD",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/TBD/decky-ramdisk/issues"
  },
  "homepage": "https://github.com/TBD/decky-ramdisk#readme",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": ["react", "react-dom"]
    }
  }
}
